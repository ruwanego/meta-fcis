{
  "name": "@meta-fcis/core",
  "version": "0.1.0",
  "description": "Runtime-agnostic semantic core for Meta-FCIS application graphs.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ruwanego/meta-fcis.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/ruwanego/meta-fcis/issues"
  },
  "homepage": "https://github.com/ruwanego/meta-fcis#readme",
  "keywords": [
    "application-graph",
    "semantic-core",
    "runtime-agnostic",
    "policy",
    "intent-planning"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "smoke": "pnpm build && node scripts/smoke.mjs",
    "smoke:expressions": "pnpm build && node scripts/expression-smoke.mjs",
    "smoke:selectors": "pnpm build && node scripts/selector-smoke.mjs",
    "smoke:policies": "pnpm build && node scripts/policy-smoke.mjs",
    "smoke:intents": "pnpm build && node scripts/intent-smoke.mjs",
    "smoke:transactions": "pnpm build && node scripts/transaction-smoke.mjs",
    "smoke:graph": "pnpm build && node scripts/graph-smoke.mjs"
  }
}
